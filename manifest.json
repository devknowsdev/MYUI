{
  "manifest_version": 3,
  "name": "MYUI",
  "version": "1.3.0",
  "description": "Searchable shortcut reference panel for annotation tagging.",
  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_title": "MYUI",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "terms_data.js",
        "defs_data.js",
        "persist.js",
        "styles.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
